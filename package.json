{
  "name": "@ethersphere/bee-factory",
  "version": "0.5.2",
  "description": "Local Ethereum Swarm development stack",
  "bin": { "bee-factory": "./bin/bee-factory.js" },
  "main": "dist/cli.js",
  "files": ["dist/", "bin/", "src/contracts/artifacts/", "src/snapshot/"],
  "scripts": {
    "compile-contracts": "hardhat compile && node scripts/copy-artifacts.js",
    "build": "tsc",
    "prepare": "npm run compile-contracts && npm run build",
    "dev": "ts-node src/cli.ts"
  },
  "dependencies": {
    "yargs": "^17.7.2",
    "dockerode": "^4.0.2",
    "ethers": "^6.11.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.11.30",
    "@types/yargs": "^17.0.32",
    "@types/dockerode": "^3.3.28",
    "hardhat": "^2.22.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "ts-node": "^10.9.2",
    "@openzeppelin/contracts": "4.8.2",
    "@openzeppelin/contracts-v3": "npm:@openzeppelin/contracts@^3.4.2"
  },
  "engines": { "node": ">=18.0.0" },
  "license": "BSD-3-Clause"
}
